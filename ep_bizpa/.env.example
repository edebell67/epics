# BizPA Environment Configuration
# Copy this file to solution/backend/.env and update values

# ===========================================
# Server Configuration
# ===========================================
PORT=5055

# ===========================================
# PostgreSQL Database
# ===========================================
# Local development defaults
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bizpa
DB_USER=postgres
DB_PASSWORD=postgres

# For Docker: use DB_HOST=postgres

# ===========================================
# Supabase Configuration (Optional)
# ===========================================
# If using Supabase for auth/storage, configure these:
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-key-here

# For Supabase Cloud:
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===========================================
# Authentication
# ===========================================
# JWT secret for signing tokens - CHANGE IN PRODUCTION!
JWT_SECRET=your-jwt-secret-change-in-production

# Token expiration (e.g., 1h, 7d, 30d)
JWT_EXPIRES_IN=7d

# ===========================================
# Debug / Development
# ===========================================
# Set to 'true' to log SQL queries
DEBUG_SQL=false

# Node environment
NODE_ENV=development
