{
  "schema_version": "2026-03-11.a1",
  "source_epic": "workstream/epic/bizPA.md",
  "quarter_reference": {
    "label_format": "Q{1-4}-{yyyy}",
    "pattern": "^Q[1-4]-\\d{4}$",
    "timezone_basis": "tenant_local_date",
    "derivation_rule": "Use transaction_date for entity assignment. Calculate quarter from the local calendar month and keep the label immutable once committed.",
    "example_labels": [
      "Q1-2026",
      "Q2-2026",
      "Q3-2026",
      "Q4-2026"
    ]
  },
  "shared_fields": {
    "unique_id": {
      "type": "uuid",
      "required_for": [
        "all_entities",
        "all_events"
      ],
      "description": "Stable immutable primary identifier."
    },
    "entity_type": {
      "type": "enum",
      "required_for": [
        "all_entities",
        "entity_linked_events"
      ],
      "description": "Canonical business entity type."
    },
    "transaction_date": {
      "type": "date",
      "required_for": [
        "monetary_entities",
        "snapshot"
      ],
      "description": "Economic or business-effective date used for quarter assignment."
    },
    "created_at": {
      "type": "datetime",
      "required_for": [
        "all_entities",
        "all_events"
      ],
      "description": "Creation timestamp in ISO-8601 format."
    },
    "created_by": {
      "type": "string",
      "required_for": [
        "all_entities",
        "all_events"
      ],
      "description": "Actor identifier, service principal, or device-linked user handle."
    },
    "quarter_reference": {
      "type": "quarter_label",
      "required_for": [
        "monetary_entities",
        "snapshot",
        "quarter_scoped_events"
      ],
      "description": "Immutable quarter label derived from transaction_date."
    },
    "counterparty_reference": {
      "type": "string",
      "required_for": [
        "monetary_entities",
        "booking",
        "client",
        "supplier",
        "reminder"
      ],
      "description": "Linked counterparty ID or canonical name when a linked record is not yet available."
    },
    "description": {
      "type": "string",
      "required_for": [
        "monetary_entities",
        "note",
        "attachment",
        "booking",
        "reminder",
        "snapshot",
        "all_events"
      ],
      "description": "Human-readable explanation of the record or event."
    },
    "category": {
      "type": "string",
      "required_for": [
        "monetary_entities"
      ],
      "description": "Export-facing business category label."
    },
    "net_amount": {
      "type": "decimal(18,2)",
      "required_for": [
        "monetary_entities"
      ],
      "description": "Net value excluding VAT."
    },
    "vat_amount": {
      "type": "decimal(18,2)",
      "required_for": [
        "monetary_entities"
      ],
      "description": "VAT value associated with the net amount."
    },
    "gross_amount": {
      "type": "decimal(18,2)",
      "required_for": [
        "monetary_entities"
      ],
      "description": "Gross value including VAT."
    },
    "vat_rate": {
      "type": "decimal(5,2)",
      "required_for": [
        "monetary_entities"
      ],
      "description": "VAT percentage rate applied to the monetary record."
    },
    "vat_type": {
      "type": "enum",
      "required_for": [
        "monetary_entities"
      ],
      "allowed_values": [
        "input",
        "output",
        "outside_scope",
        "exempt"
      ],
      "description": "Canonical VAT treatment."
    },
    "status": {
      "type": "enum",
      "required_for": [
        "all_entities"
      ],
      "description": "Lifecycle status governed by entity-specific state sets."
    },
    "commit_mode": {
      "type": "enum",
      "required_for": [
        "all_entities"
      ],
      "allowed_values": [
        "manual",
        "auto"
      ],
      "description": "Whether commit required explicit confirmation or was performed under controlled auto-commit."
    },
    "source_type": {
      "type": "enum",
      "required_for": [
        "all_entities",
        "all_events"
      ],
      "allowed_values": [
        "voice",
        "manual",
        "attachment",
        "import",
        "system"
      ],
      "description": "How the record entered the system."
    }
  },
